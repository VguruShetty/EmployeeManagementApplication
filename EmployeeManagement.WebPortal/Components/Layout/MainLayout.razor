@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @* This section handles the Username and Login/Logout links *@
            <AuthorizeView>
                <Authorized>
                    @* Only shown when logged in *@
                    <span class="me-3">
                        <span class="bi bi-person-fill" aria-hidden="true"></span>
                        <strong>@context.User.Identity?.Name</strong>
                    </span>
                    <a href="Account/Logout" class="btn btn-outline-danger btn-sm">
                        <span class="bi oi-power-standby" aria-hidden="true"></span> Logout
                    </a>
                </Authorized>
                <NotAuthorized>
                    @* Only shown when guest *@
                    <a href="Account/Login" class="btn btn-outline-primary btn-sm">
                        <span class="bi oi-lock-locked" aria-hidden="true"></span> Login
                    </a>
                </NotAuthorized>
            </AuthorizeView>

            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>