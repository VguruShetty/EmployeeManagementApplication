@implements IDisposable
@inject NavigationManager NavigationManager
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">EmployeeManagement.WebPortal</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/editemployee" @onclick="HandleClick" Match="NavLinkMatch.All">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Create
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/editemployee/1" Match="NavLinkMatch.All">
                <span class="bi bi-pencil-nav-menu" aria-hidden="true"></span> Edit
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/Account/Login" Match="NavLinkMatch.All">
                <span class="bi oi-lock-locked" aria-hidden="true"></span> Login
            </NavLink>
        </div>
    </nav>
</div>

@code{
	[Inject]
	private NavigationManager NavigationManager { get; set; }

    private void HandleClick()
    {
        // This method is intentionally left empty. It serves as a placeholder for the @onclick event on the "Create" NavLink.
        // The @onclick event is used to ensure that the navigation menu closes when the "Create" link is clicked, especially on smaller screens where the menu is collapsible.
		NavigationManager.NavigateTo("editemployee", true);
	}
}@code {
    private string? currentUrl;
    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

}