@page "/Account/Logout"
@using Microsoft.AspNetCore.Identity
@using EmployeeManagement.WebPortal.Data
@using Microsoft.AspNetCore.Mvc.RazorPages
@inject SignInManager<EmployeeManagementWebPortalUser> SignInManager
@inject ILogger<LogoutModel> Logger
@functions {
    // This acts like your Logout.cshtml.cs code-behind
    public class LogoutModel : PageModel { }

    public async Task<IActionResult> OnGet()
    {
        await SignInManager.SignOutAsync();
        Logger.LogInformation("User logged out via GET.");

        // Redirect to home page immediately
        return LocalRedirect("~/");
    }

    public async Task<IActionResult> OnPost()
    {
        await SignInManager.SignOutAsync();
        Logger.LogInformation("User logged out via POST.");

        return LocalRedirect("~/");
    }
}
@{
    Layout = null; // Bypasses the main layout to avoid errors
}

<!DOCTYPE html>
<html>
<head>
    <title>Logging out...</title>
</head>
<body>
    <p>Please wait, you are being logged out...</p>
</body>
</html>