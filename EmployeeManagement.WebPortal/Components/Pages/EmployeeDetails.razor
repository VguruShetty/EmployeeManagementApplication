@page "/employeedetails/{id}"
@inherits EmployeeDetailsBase

@if(Employee == null)
{
	<p><em>Loading...</em></p>
	<div class="spinner"></div>
}
else
{
	<div class="row justify-content-center m-3">
		<div class="col-sm-8">
			<div class="card">
				<div class="card-header">
					<h1>@Employee.FirstName @Employee.LastName @Coordinates</h1>
				</div>
				<div class="card-body text-center">
					<img class="card-img-top" src="@Employee.PhotoPath" 
						@onmousemove = "@Mouse_Move"/>

					<h4>Employee ID : @Employee.EmployeeId</h4>
					<h4>Email : @Employee.Email</h4>
					<h4>Department : @(Employee.Department == null ? "NA" : Employee.Department.DepartmentName)</h4>
				</div>
				<div class="card-footer text-center">
					<a href="/" class="btn btn-primary m-1">Back</a>
					<a href="#" class="btn btn-primary m-1">Edit</a>
					<a href="#" class="btn btn-danger m-1">Delete</a>
				</div>
			</div>

		</div>
	</div>
}

