@page "/"

<PageTitle>Home - Employee Management</PageTitle>

<AuthorizeView>
    <Authorized>
        @* This is what the user sees AFTER logging in *@
        <div class="container mt-5 text-center">
            <h1 class="display-4">Welcome back, @context.User.Identity?.Name!</h1>
            <p class="lead">You are now logged into the Employee Management Portal.</p>
            <hr class="my-4" />
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">Manage Employees</h5>
                            <p class="card-text">View, edit, or add new employees to the database.</p>
                            <a href="editemployee" class="btn btn-primary">Go to Dashboard</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">System Status</h5>
                            <p class="card-text">Database is connected and version 8.0.25 is active.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        @* This is what guests see (The "First Page" logic) *@
        <div class="container mt-5 text-center">
            <div class="jumbotron shadow p-5 mb-5 bg-white rounded">
                <h1 class="display-4">Access Restricted</h1>
                <p class="lead">Please log in to manage employees and view records.</p>
                <hr class="my-4" />
                <p>Use your registered credentials to enter the portal.</p>
                <a href="Account/Login" class="btn btn-success btn-lg px-5 mt-3">
                    <span class="bi oi-lock-locked" aria-hidden="true"></span> Click Here to Login
                </a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>