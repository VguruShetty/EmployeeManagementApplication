
@rendermode InteractiveServer
@inherits DisplayEmployeeBase


<div class="card">
    <div class="card-header">
        <h3>
            <input type="checkbox" @onchange="CheckBoxChanged"/>
            @Employee.FirstName @Employee.LastName</h3>
    </div>
    <img class="card-img-top" height="200px" width="auto" src="@Employee.PhotoPath" />
    @if (ShowFooter)
    {
        <div class="card-footer text-center">
            <a href="@($"/employeedetails/{Employee.EmployeeId}")" class="btn btn-primary m-1">View</a>
            <a href="#" class="btn btn-primary m-1">Edit</a>
            <a href="#" class="btn btn-danger m-1">Delete</a>
        </div>
    }
    
</div>